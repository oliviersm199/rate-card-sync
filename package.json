{
    "name": "@oliviersm199/rate-card-sync",
    "version": "0.1.3",
    "description": "CLI to extract and sync billing rate card pricing as YAML. Metronome supported today.",
    "type": "module",
    "main": "./dist/cli.js",
    "types": "./dist/cli.d.ts",
    "bin": {
        "rate-card": "./dist/cli.js"
    },
    "exports": {
        ".": {
            "types": "./dist/cli.d.ts",
            "import": "./dist/cli.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsx src/cli.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "coverage": "vitest run --coverage",
        "prepublishOnly": "npm run build && npm run test"
    },
    "keywords": [
        "metronome",
        "billing",
        "rate-card",
        "pricing",
        "cli",
        "yaml"
    ],
    "license": "MIT",
    "author": "oliviersm199",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/oliviersm199/rate-card-sync.git"
    },
    "bugs": {
        "url": "https://github.com/oliviersm199/rate-card-sync/issues"
    },
    "homepage": "https://github.com/oliviersm199/rate-card-sync#readme",
    "engines": {
        "node": ">=20"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@metronome/sdk": "^3.4.1",
        "commander": "^15.0.0",
        "dequal": "^2.0.3",
        "picocolors": "^1.1.1",
        "uuid": "^14.0.0",
        "yaml": "^2.7.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^26.0.1",
        "@types/uuid": "^10.0.0",
        "@vitest/coverage-v8": "^4.1.9",
        "prettier": "^3.5.3",
        "tsx": "^4.19.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    }
}
